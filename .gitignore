# Dependencies
node_modules

# Output (SvelteKit Build)
.output
.vercel
.netlify
.wrangler
/.svelte-kit
/build

# OS files
.DS_Store
Thumbs.db

# Env files
.env
.env.*
!.env.example
!.env.test

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# --- FIDO Simulator (External Data Folder) ---
# data/fido/api 内の JSON は API 定義なので Git で管理（共有）する
# data/fido/key 内の JSON は実行時に生成される「鍵データ」なので Git から除外する
data/fido/key/*.json

# 鍵フォルダ自体を Git に認識させるための .gitkeep は許可する場合
!data/fido/key/.gitkeep